{
  "name": "bluebird-cockpit",
  "version": "1.0.0",
  "description": "BluebirdCockpit – Full-stack project management dashboard",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "npm run dev --prefix api",
    "dev:client": "npm start --prefix client",
    "test": "npm run test:api && npm run test:client",
    "test:api": "npm test --prefix api",
    "test:client": "npm test --prefix client -- --watchAll=false",
    "lint": "npm run lint:api && npm run lint:client",
    "lint:api": "npm run lint --prefix api",
    "lint:client": "npm run lint --prefix client",
    "install:all": "npm install && npm install --prefix api && npm install --prefix client",
    "db:migrate": "npm run db:migrate --prefix api",
    "db:seed": "npm run db:seed --prefix api",
    "db:reset": "npm run db:reset --prefix api",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "globals": "^17.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
