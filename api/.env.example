# ============================================================
# BluebirdCockpit API — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=8000

# --- Database (MySQL) ---
# For local dev, use localhost. For Docker, use the service name (e.g. "mysql")
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bluebird
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# --- Database Init ---
# Set to "true" ONLY when you need to sync/create tables for the first time.
# After first run, set back to "false". Prefer using migrations instead.
INIT_DB=false

# --- JWT Authentication ---
# MUST be a random string of at least 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_string_minimum_32_chars
JWT_EXPIRES_IN=48h

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# --- Email Domain Restriction ---
# Only users with this email domain can be registered
ALLOWED_EMAIL_DOMAIN=tatatechnologies.com

# --- Logging ---
# Options: error, warn, info, http, debug
LOG_LEVEL=info
